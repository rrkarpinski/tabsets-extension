{
  "manifest_version": 4,
  "name": "TabSets Sync",
  "version": "2.2.0",
  "description": "Track changes between your current tabs and a saved tab set. Stored as a bookmark folder.",
  "permissions": ["tabs", "bookmarks", "storage"],
  "action": {
    "default_title": "TabSets Sync",
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}